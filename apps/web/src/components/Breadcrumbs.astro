---
import { ChevronRight } from 'lucide-react';

export interface Props {
  items: Array<{ name: string; path: string }>;
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-sm">
  <ol class="flex flex-wrap items-center gap-1.5 text-base-400">
    {
      items.map((item, index) => (
        <li class="flex items-center gap-1.5">
          {index > 0 && <ChevronRight size={14} className="text-base-600" aria-hidden="true" />}
          {index === items.length - 1 ? (
            <span class="text-base-200" aria-current="page">
              {item.name}
            </span>
          ) : (
            <a href={item.path} class="transition-colors hover:text-interactive">
              {item.name}
            </a>
          )}
        </li>
      ))
    }
  </ol>
</nav>
