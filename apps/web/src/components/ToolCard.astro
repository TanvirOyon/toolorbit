---
import ToolIcon from './ToolIcon.astro';
import type { ToolDefinition } from '@toolorbit/tool-registry';

export interface Props {
  tool: ToolDefinition;
  compact?: boolean;
}

const { tool, compact = false } = Astro.props;
---

<a
  href={`/tools/${tool.slug}`}
  class={`group flex gap-4 rounded-xl border border-base-700 bg-base-900 transition-all duration-150 hover:border-interactive/40 hover:shadow-glow ${
    compact ? 'items-center p-3' : 'flex-col p-5'
  }`}
>
  <div class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-interactive-muted text-interactive">
    <ToolIcon name={tool.icon} size={20} />
  </div>
  <div class="min-w-0">
    <h3 class={`font-display font-semibold text-base-50 group-hover:text-interactive ${compact ? 'text-sm' : 'text-base'}`}>
      {tool.name}
    </h3>
    {!compact && (
      <p class="mt-1 text-sm text-base-400 line-clamp-2">{tool.description}</p>
    )}
  </div>
</a>
