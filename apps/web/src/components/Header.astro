---
import { Orbit } from 'lucide-react';
import SearchTrigger from './SearchTrigger.astro';
import ThemeToggle from '../islands/ThemeToggle.tsx';
import CommandPalette from '../islands/CommandPalette.tsx';
import MobileNav from '../islands/ui/MobileNav.tsx';
import { CATEGORIES, getCategoryCounts } from '@toolorbit/tool-registry';

const counts         = getCategoryCounts(CATEGORIES);
const liveCategories = CATEGORIES.filter((c) => counts[c.slug] > 0);
const mobileCategories = liveCategories.map((c) => ({
  slug: c.slug, name: c.name, count: counts[c.slug] ?? 0,
}));

const currentPath = Astro.url.pathname;
function isActive(path: string) {
  return currentPath === path || currentPath.startsWith(path + '/');
}
---

<header class="sticky top-0 z-header border-b border-base-700 bg-base-950/90 backdrop-blur-sm">
  <div class="mx-auto flex h-16 max-w-6xl items-center gap-4 px-4 sm:px-6">

    <!-- Logo -->
    <a href="/" class="flex shrink-0 items-center gap-2 font-display text-lg font-bold text-base-50">
      <Orbit size={22} className="text-interactive" aria-hidden="true" />
      <span>ToolOrbit</span>
    </a>

    <!-- Desktop nav (md+) -->
    <nav class="hidden items-center gap-5 md:flex" aria-label="Main navigation">
      {liveCategories.slice(0, 4).map((category) => (
        <a href={`/${category.slug}-tools`}
          class={`text-sm transition-colors ${isActive(`/${category.slug}-tools`) ? 'text-base-50 font-medium' : 'text-base-300 hover:text-base-50'}`}>
          {category.name}
        </a>
      ))}
      <a href="/blog"
        class={`text-sm transition-colors ${isActive('/blog') ? 'text-base-50 font-medium' : 'text-base-300 hover:text-base-50'}`}>
        Blog
      </a>
    </nav>

    <!-- Right controls -->
    <div class="ml-auto flex items-center gap-2">
      <!-- Search - visible sm+ on desktop -->
      <div class="hidden sm:block">
        <SearchTrigger />
      </div>
      <ThemeToggle client:idle />
      <!-- Dashboard link (desktop) -->
      <a href="/dashboard"
        class="hidden items-center gap-1.5 rounded-lg border border-base-700 bg-base-900 px-3 py-1.5 text-sm text-base-300 transition-colors hover:border-base-500 hover:text-base-50 md:flex">
        Dashboard
      </a>
      <!-- Hamburger (mobile only) -->
      <MobileNav client:idle categories={mobileCategories} />
    </div>
  </div>
</header>

<!-- Command palette mounted globally once -->
<CommandPalette client:idle />
