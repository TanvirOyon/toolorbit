---
import ToolIcon from './ToolIcon.astro';
import type { CategoryDefinition } from '@toolorbit/tool-registry';

export interface Props {
  category: CategoryDefinition;
  toolCount: number;
}

const { category, toolCount } = Astro.props;
const isComingSoon = toolCount === 0;
const Tag = isComingSoon ? 'div' : 'a';
---

<Tag
  href={isComingSoon ? undefined : `/${category.slug}-tools`}
  class={`group relative block rounded-xl border border-base-700 bg-base-900 p-5 transition-all duration-150 ${
    isComingSoon ? 'opacity-60 cursor-default' : 'hover:border-interactive/40 hover:shadow-glow'
  }`}
>
  <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-interactive-muted text-interactive">
    <ToolIcon name={category.icon} size={20} />
  </div>
  <h3 class="font-display text-base font-semibold text-base-50">{category.name}</h3>
  <p class="mt-1 line-clamp-2 text-sm text-base-400">{category.description}</p>
  <p class="mt-3 text-xs font-medium text-base-400">
    {isComingSoon ? 'Coming soon' : `${toolCount} tool${toolCount === 1 ? '' : 's'}`}
  </p>
</Tag>
