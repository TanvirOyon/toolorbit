---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import type { ToolDefinition, CategoryDefinition } from '@toolorbit/tool-registry';
import { CATEGORIES } from '@toolorbit/tool-registry';
import { buildToolJsonLd, buildBreadcrumbJsonLd } from '../lib/seo';

export interface Props {
  tool: ToolDefinition;
}

const { tool } = Astro.props;
const category = CATEGORIES.find((c) => c.slug === tool.category) as CategoryDefinition;

const breadcrumbItems = [
  { name: 'Home', path: '/' },
  { name: category.name, path: `/${category.slug}-tools` },
  { name: tool.name, path: `/tools/${tool.slug}` },
];

const jsonLd = [...buildToolJsonLd(tool), buildBreadcrumbJsonLd(breadcrumbItems)];
---

<BaseLayout
  title={tool.seo.title}
  description={tool.seo.description}
  canonicalPath={`/tools/${tool.slug}`}
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-4xl px-4 py-8 sm:px-6 sm:py-12">
    <Breadcrumbs items={breadcrumbItems} />
    <header class="mt-4 mb-8">
      <h1 class="font-display text-3xl font-bold text-base-50 sm:text-4xl">{tool.name}</h1>
      <p class="mt-2 text-base-300">{tool.description}</p>
    </header>

    <slot />
  </div>
</BaseLayout>
