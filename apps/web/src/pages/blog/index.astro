---
export const prerender = true;
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildBreadcrumbJsonLd } from '../../lib/seo';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const featured = allPosts.filter(p => p.data.featured);
const recent   = allPosts.filter(p => !p.data.featured);

const breadcrumb = buildBreadcrumbJsonLd([
  { name: 'Home', path: '/' },
  { name: 'Blog', path: '/blog' },
]);
---

<BaseLayout
  title="ToolOrbit Blog - Guides, Tips & Developer Resources"
  description="Practical guides on PDF compression, JSON tools, SEO meta tags, image formats, and more. Written by the ToolOrbit team."
  canonicalPath="/blog"
  jsonLd={[breadcrumb]}
>
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
    <header class="mb-12">
      <h1 class="font-display text-4xl font-bold text-base-50">Blog</h1>
      <p class="mt-3 text-base-300">Practical guides on tools, SEO, and developer workflows.</p>
    </header>

    {featured.length > 0 && (
      <section class="mb-12">
        <h2 class="mb-5 text-xs font-medium uppercase tracking-widest text-base-500">Featured</h2>
        <div class="grid gap-6 sm:grid-cols-2">
          {featured.map(post => (
            <a href={`/blog/${post.id}`}
              class="group flex flex-col rounded-xl border border-base-700 bg-base-900 p-6 transition-all hover:border-interactive/40 hover:shadow-glow">
              <span class="mb-2 text-xs font-medium uppercase tracking-wide text-interactive">{post.data.category}</span>
              <h3 class="font-display text-lg font-semibold text-base-50 group-hover:text-interactive leading-snug">
                {post.data.title}
              </h3>
              <p class="mt-2 flex-1 text-sm text-base-400 line-clamp-3">{post.data.description}</p>
              <p class="mt-4 text-xs text-base-500">
                {new Date(post.data.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
            </a>
          ))}
        </div>
      </section>
    )}

    {recent.length > 0 && (
      <section>
        <h2 class="mb-5 text-xs font-medium uppercase tracking-widest text-base-500">All posts</h2>
        <div class="divide-y divide-base-700">
          {recent.map(post => (
            <a href={`/blog/${post.id}`}
              class="group flex items-start gap-4 py-5 transition-colors hover:text-interactive">
              <div class="min-w-0 flex-1">
                <span class="text-xs font-medium uppercase tracking-wide text-base-500">{post.data.category}</span>
                <h3 class="mt-1 font-display font-semibold text-base-50 group-hover:text-interactive">
                  {post.data.title}
                </h3>
                <p class="mt-1 text-sm text-base-400 line-clamp-2">{post.data.description}</p>
              </div>
              <time class="shrink-0 pt-1 text-xs text-base-500">
                {new Date(post.data.publishDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
            </a>
          ))}
        </div>
      </section>
    )}

    {allPosts.length === 0 && (
      <p class="text-base-400">No posts yet. Check back soon.</p>
    )}
  </div>
</BaseLayout>
