---
export const prerender = true;
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { buildBreadcrumbJsonLd, buildOrganizationJsonLd, absoluteUrl } from '../../lib/seo';
import { SITE_NAME } from '../../lib/config';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  // Note: the route param is named "slug" (matches the [...slug].astro filename),
  // but the value comes from the content entry's `id` field - the glob() loader's
  // default id derivation, not a `slug` property on the entry itself.
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
// Astro 6 Content Layer API: render() is a standalone function import,
// not a method on the entry (the old `post.render()` was removed).
const { Content } = await render(post);

const breadcrumbItems = [
  { name: 'Home', path: '/' },
  { name: 'Blog', path: '/blog' },
  { name: post.data.title, path: `/blog/${post.id}` },
];

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  url: absoluteUrl(`/blog/${post.id}`),
  datePublished: post.data.publishDate,
  dateModified: post.data.updatedDate ?? post.data.publishDate,
  author: { '@type': 'Person', name: post.data.author },
  // Google's structured data guidelines treat Article/BlogPosting without
  // these three as incomplete for rich-result eligibility (Search Console
  // will flag "missing field" warnings otherwise).
  publisher: { ...buildOrganizationJsonLd(), '@type': 'Organization', name: SITE_NAME },
  mainEntityOfPage: { '@type': 'WebPage', '@id': absoluteUrl(`/blog/${post.id}`) },
  image: absoluteUrl('/og-default.png'),
};
---

<BaseLayout
  title={`${post.data.title} | ToolOrbit Blog`}
  description={post.data.description}
  canonicalPath={`/blog/${post.id}`}
  jsonLd={[articleJsonLd, buildBreadcrumbJsonLd(breadcrumbItems)]}
>
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <Breadcrumbs items={breadcrumbItems} />

    <header class="mt-6 mb-10">
      <span class="text-xs font-medium uppercase tracking-wide text-interactive">
        {post.data.category}
      </span>
      <h1 class="mt-2 font-display text-3xl font-bold text-base-50 sm:text-4xl leading-tight">
        {post.data.title}
      </h1>
      <div class="mt-4 flex items-center gap-3 text-sm text-base-500">
        <span>{post.data.author}</span>
        <span>·</span>
        <time datetime={post.data.publishDate}>
          {new Date(post.data.publishDate).toLocaleDateString('en-US', {
            year: 'numeric', month: 'long', day: 'numeric'
          })}
        </time>
        {post.data.updatedDate && (
          <>
            <span>·</span>
            <span>Updated {new Date(post.data.updatedDate).toLocaleDateString('en-US', {
              year: 'numeric', month: 'short', day: 'numeric'
            })}</span>
          </>
        )}
      </div>
    </header>

    <article class="prose prose-invert max-w-none
      prose-headings:font-display prose-headings:text-base-50 prose-headings:font-semibold
      prose-p:text-base-300 prose-p:leading-relaxed
      prose-a:text-interactive prose-a:no-underline hover:prose-a:underline
      prose-strong:text-base-100 prose-strong:font-semibold
      prose-code:text-interactive prose-code:bg-base-800 prose-code:rounded
      prose-code:px-1 prose-code:py-0.5 prose-code:font-mono prose-code:text-xs
      prose-pre:bg-base-950 prose-pre:border prose-pre:border-base-700
      prose-blockquote:border-l-interactive prose-blockquote:text-base-400
      prose-th:text-base-200 prose-td:text-base-300 prose-hr:border-base-700
      prose-li:text-base-300">
      <Content />
    </article>

    <div class="mt-12 border-t border-base-700 pt-8">
      <a href="/blog" class="text-sm text-base-400 hover:text-interactive transition-colors">
        ← All posts
      </a>
    </div>
  </div>
</BaseLayout>
