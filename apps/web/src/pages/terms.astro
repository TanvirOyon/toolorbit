---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildBreadcrumbJsonLd } from '../lib/seo';
const breadcrumb = buildBreadcrumbJsonLd([{ name: 'Home', path: '/' }, { name: 'Terms', path: '/terms' }]);
---
<BaseLayout title="Terms of Service | ToolOrbit" description="Terms of service for using ToolOrbit's free online tools." canonicalPath="/terms" jsonLd={[breadcrumb]}>
  <div class="mx-auto max-w-2xl px-4 py-16 sm:px-6">
    <h1 class="font-display text-4xl font-bold text-base-50 mb-2">Terms of Service</h1>
    <p class="text-sm text-base-500 mb-10">Last updated: June 28, 2026</p>
    <div class="prose prose-invert max-w-none prose-headings:font-display prose-headings:text-base-50 prose-p:text-base-300 prose-li:text-base-300 prose-a:text-interactive prose-strong:text-base-100">
      <h2>Acceptance</h2>
      <p>By using ToolOrbit, you agree to these terms. If you do not agree, please do not use the service.</p>
      <h2>Service</h2>
      <p>ToolOrbit provides free browser-based tools. Tools are provided "as is" without warranty of any kind. We make no guarantees about the accuracy, reliability, or fitness for a particular purpose of any tool output.</p>
      <h2>Acceptable use</h2>
      <p>You may use ToolOrbit for any lawful purpose. You may not use automated scripts to abuse the service, attempt to reverse-engineer or circumvent any security measures, or use the service to process files you do not have the right to process.</p>
      <h2>Accounts</h2>
      <p>You are responsible for maintaining the security of your account. We reserve the right to suspend or terminate accounts that violate these terms.</p>
      <h2>Limitation of liability</h2>
      <p>ToolOrbit is not liable for any loss or damage arising from the use or inability to use the service, including but not limited to data loss. Always keep backups of important files before processing them with any tool.</p>
      <h2>Changes</h2>
      <p>We may update these terms. Continued use of the service after changes constitutes acceptance of the new terms.</p>
      <h2>Contact</h2>
      <p>Questions: <a href="mailto:tanviroyon001@gmail.com">tanviroyon001@gmail.com</a></p>
    </div>
  </div>
</BaseLayout>
