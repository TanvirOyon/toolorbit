---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchTrigger from '../components/SearchTrigger.astro';
---

<BaseLayout
  title="Page Not Found | ToolOrbit"
  description="The page you're looking for doesn't exist. Search for any tool or browse categories."
  canonicalPath="/404"
>
  <div class="flex min-h-[calc(100vh-10rem)] flex-col items-center justify-center px-4 py-20 text-center">

    <!-- Big 404 number -->
    <div class="font-display text-[8rem] font-bold leading-none text-base-800 sm:text-[12rem]">
      404
    </div>

    <h1 class="mt-2 font-display text-2xl font-bold text-base-50 sm:text-3xl">
      Tool not found
    </h1>
    <p class="mx-auto mt-3 max-w-sm text-base text-base-400">
      The page you're looking for doesn't exist, or it may have moved. Try searching for the tool you need.
    </p>

    <!-- Search CTA -->
    <div class="mt-8">
      <SearchTrigger />
    </div>

    <!-- Browse link -->
    <a
      href="/"
      class="mt-4 inline-flex items-center gap-1.5 text-sm text-base-400 transition-colors hover:text-interactive"
    >
      ← Browse all tools
    </a>

  </div>
</BaseLayout>
