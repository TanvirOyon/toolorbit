---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ToolCard from '../components/ToolCard.astro';
import { CATEGORIES, getToolsByCategory } from '@toolorbit/tool-registry';
import { buildCategoryJsonLd, buildBreadcrumbJsonLd } from '../lib/seo';
import type { CategoryDefinition } from '@toolorbit/tool-registry';

export function getStaticPaths() {
  // Only generate a hub page for categories that actually have at least
  // one live tool - never publish a thin/empty page for SEO purposes.
  return CATEGORIES.filter((category) => getToolsByCategory(category.slug).length > 0).map(
    (category) => ({
      params: { category: category.slug },
      props: { category },
    })
  );
}

const { category } = Astro.props as { category: CategoryDefinition };
const tools = getToolsByCategory(category.slug);

const breadcrumbItems = [
  { name: 'Home', path: '/' },
  { name: category.name, path: `/${category.slug}-tools` },
];

const jsonLd = [
  buildCategoryJsonLd(category, tools.length),
  buildBreadcrumbJsonLd(breadcrumbItems),
];

const title = `${category.name} - ${tools.length} Free Online Tools | ToolOrbit`;
const description = `${category.description} Browse all ${tools.length} ${category.name.toLowerCase()} on ToolOrbit - free, fast, and entirely client-side.`;
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={`/${category.slug}-tools`}
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <Breadcrumbs items={breadcrumbItems} />

    <header class="mt-4 mb-10 max-w-2xl">
      <h1 class="font-display text-3xl font-bold text-base-50 sm:text-4xl">{category.name}</h1>
      <p class="mt-3 text-base-300">{category.description}</p>
    </header>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {tools.map((tool) => <ToolCard tool={tool} />)}
    </div>
  </div>
</BaseLayout>
