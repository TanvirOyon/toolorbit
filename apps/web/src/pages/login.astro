---
/**
 * /login - sign-in page.
 * Must be SSR (prerender = false) so we can check the session server-side
 * and redirect already-authenticated users away from here.
 */
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import LoginIsland from '../islands/dashboard/LoginIsland';
import { env } from 'cloudflare:workers';
import { createAuth } from '../lib/auth';

const auth = createAuth(env);
const session = await auth.api.getSession({ headers: Astro.request.headers });

// Already logged in → go straight to the dashboard
if (session) return Astro.redirect('/dashboard');

// Pick up the redirect target (e.g. came from dashboard when not logged in)
const next = Astro.url.searchParams.get('next') ?? '/dashboard';
---

<BaseLayout
  title="Sign in to ToolOrbit"
  description="Sign in with Google or GitHub to save your favourite tools and see your usage history."
  canonicalPath="/login"
>
  <div class="flex min-h-[calc(100vh-4rem)] items-center justify-center px-4 py-16">
    <div class="w-full max-w-sm">
      <LoginIsland client:load redirectTo={next} />
    </div>
  </div>
</BaseLayout>
